@page
@model diplom_1.Pages.ResetPasswordModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Смена пароля</title>
    <link rel="stylesheet" href="~/css/login.css?v=@DateTime.Now.Ticks" />
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const svg = button.querySelector('svg');

            if (!input || !svg) return;

            if (input.type === "password") {
                input.type = "text";
                svg.innerHTML = '<circle cx="12" cy="12" r="3"/><path d="M22 12c-2.667 4.667-6 7-10 7s-7.333-2.333-10-7c2.667-4.667 6-7 10-7s7.333 2.333 10 7z"/><line x1="1" y1="1" x2="23" y2="23"/>';
            } else {
                input.type = "password";
                svg.innerHTML = '<circle cx="12" cy="12" r="3"/><path d="M22 12c-2.667 4.667-6 7-10 7s-7.333-2.333-10-7c2.667-4.667 6-7 10-7s7.333 2.333 10 7z"/>';
            }
        }
    </script>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <h1 class="auth-title">Смена пароля</h1>
            <h2 class="auth-subtitle">Введите новый пароль</h2>

            @if (Model.IsSuccess)
            {
                <div class="message-container" style="margin-bottom: 24px;">
                    <p class="success-message">@Model.Message</p>
                </div>
                <a asp-page="/Login" class="btn-login" style="display: block; text-decoration: none;">Войти в систему</a>
            }
            else
            {
                <form method="post" class="auth-form">
                    <input type="hidden" asp-for="Token" />

                    <div class="form-group">
                        <input asp-for="NewPassword" class="form-input" type="password" placeholder="Новый пароль" id="new-password" />
                        <button type="button" class="password-toggle" onclick="togglePassword('new-password', this)" tabindex="-1">
                            <svg class="eye-icon" viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="3" />
                                <path d="M22 12c-2.667 4.667-6 7-10 7s-7.333-2.333-10-7c2.667-4.667 6-7 10-7s7.333 2.333 10 7z" />
                            </svg>
                        </button>
                        <span asp-validation-for="NewPassword" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <input asp-for="ConfirmPassword" class="form-input" type="password" placeholder="Подтвердите пароль" id="confirm-password" />
                        <button type="button" class="password-toggle" onclick="togglePassword('confirm-password', this)" tabindex="-1">
                            <svg class="eye-icon" viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="3" />
                                <path d="M22 12c-2.667 4.667-6 7-10 7s-7.333-2.333-10-7c2.667-4.667 6-7 10-7s7.333 2.333 10 7z" />
                            </svg>
                        </button>
                        <span asp-validation-for="ConfirmPassword" class="error-message"></span>
                    </div>

                    <button type="submit" class="btn-login">Сохранить</button>

                    @if (!string.IsNullOrEmpty(Model.Message) && !Model.IsSuccess)
                    {
                        <div class="message-container">
                            <p class="error-message">@Model.Message</p>
                        </div>
                    }
                </form>
            }

            <div class="link-text">
                <a asp-page="/Login">Вернуться к входу</a>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>