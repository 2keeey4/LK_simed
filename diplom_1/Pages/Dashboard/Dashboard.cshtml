@page
@model diplom_1.Pages.Dashboard.DashboardModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Профиль пользователя";
}

<link rel="stylesheet" href="~/css/dashboard.css" />
<script defer src="~/js/dashboard.js"></script>

<div class="profile-container">
    <h2 class="profile-title">Профиль пользователя</h2>

    <div class="profile-card">
        <div class="profile-photo-section">
            <img src="@Url.Content(HttpContext.Session.GetString("PhotoPath") ?? "~/icons/default-avatar.png")"
                 alt="Фото" class="profile-photo" id="profilePhoto" />

            <label class="photo-upload">
                <input type="file" id="photoInput" accept="image/*" hidden />
                <button type="button" class="btn secondary" id="changePhotoBtn">Изменить фото</button>
            </label>
        </div>

        <div class="profile-info">
            <label>ФИО</label>
            <input type="text" id="profileFullName" value="@HttpContext.Session.GetString("FullName")" />

            <label>Email</label>
            <input type="email" id="profileEmail" value="@HttpContext.Session.GetString("Email")" />

           

            <div class="actions">
                <button type="button" class="btn primary" id="saveProfileBtn">Сохранить</button>
            </div>
        </div>
    </div>
</div>
