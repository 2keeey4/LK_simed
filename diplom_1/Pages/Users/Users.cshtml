@page
@model diplom_1.Pages.Users.UsersModel

@{
    ViewData["Title"] = "Администрирование";
    Layout = "_DashboardLayout";
}

<link rel="stylesheet" href="~/css/users.css" />

<script>
    window.currentUserId = @Model.CurrentUserId;
</script>

<script defer src="~/js/users.js"></script>

<div class="admin-container">

    <div class="main-tabs">
        <button class="main-tab active" data-tab="tab-users">Пользователи</button>
        <button class="main-tab" data-tab="tab-orgs">Организации</button>
        <button class="main-tab" data-tab="tab-branches">Филиалы</button>
    </div>

    <div id="tab-users" class="tab-section active">
        <div class="section-header">
            <div class="filter-group">
                <input type="text"
                       id="searchUser"
                       placeholder="Поиск по ФИО, логину, email..."
                       class="search-input" />

                <button class="btn secondary" id="sortUsers">
                    Сортировать A–Я
                </button>

                <div class="dropdown">
                    <button class="btn secondary dropdown-toggle" id="userOrgFilterBtn">
                        Фильтр по организации ▾
                    </button>

                    <div class="dropdown-menu hidden" id="userOrgFilterDropdown">
                        <label>
                            <input type="checkbox" value="all" checked>
                            Все организации
                        </label>
                    </div>
                </div>

                <div class="dropdown">
                    <button class="btn secondary dropdown-toggle" id="userBranchFilterBtn">
                        Фильтр по филиалу ▾
                    </button>

                    <div class="dropdown-menu hidden" id="userBranchFilterDropdown">
                        <label>
                            <input type="checkbox" value="all" checked>
                            Все филиалы
                        </label>
                    </div>
                </div>
            </div>

            <button class="btn primary" id="btnAddUser">
                Добавить пользователя
            </button>
        </div>

        <table class="main-table" id="usersTable">
            <thead>
                <tr>
                    <th>ФИО</th>
                    <th>Логин</th>
                    <th>Email</th>
                    <th>Организации</th>
                    <th>Филиалы</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr data-user-id="@user.Id">
                        <td>@user.FullName</td>
                        <td>@user.Login</td>
                        <td>@user.Email</td>
                        <td>@string.Join(", ", user.Organizations)</td>
                        <td>@string.Join(", ", user.Branches)</td>
                        <td>
                            <button class="btn small danger delete-user" type="button">
                                Удалить
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div id="usersPagination" class="pagination-container"></div>
    </div>

    <div id="tab-orgs" class="tab-section">
        <div class="section-header">
            <div class="filter-group">
                <input type="text"
                       id="searchOrg"
                       placeholder="Поиск по названию..."
                       class="search-input" />

                <button class="btn secondary" id="sortOrgs">
                    Сортировать A–Я
                </button>
            </div>

            @if (Model.CanCreateOrganization)
            {
                <button class="btn primary" id="btnAddOrg">
                    Добавить организацию
                </button>
            }
        </div>

        <table class="main-table">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>ИНН</th>
                    <th>КПП</th>
                    <th>ОГРН</th>
                    <th>Лимит часов</th>
                    <th>Продукты</th>
                    <th></th>
                </tr>
            </thead>

            <tbody id="orgsBody"></tbody>
        </table>

        <div id="orgsPagination" class="pagination-container"></div>
    </div>

    <div id="tab-branches" class="tab-section">
        <div class="section-header">
            <div class="filter-group">
                <div class="dropdown">
                    <button class="btn secondary dropdown-toggle" id="branchOrgFilterBtn">
                        Фильтр организаций ▾
                    </button>

                    <div class="dropdown-menu hidden" id="branchOrgFilterDropdown">
                        <label>
                            <input type="checkbox" value="all" checked>
                            Все организации
                        </label>
                    </div>
                </div>

                <input type="text"
                       id="searchBranch"
                       placeholder="Поиск по названию филиала..."
                       class="search-input" />

                <button class="btn secondary" id="sortBranches">
                    Сортировать A–Я
                </button>
            </div>

            @if (Model.CanCreateBranch)
            {
                <button class="btn primary" id="btnAddBranch">
                    Добавить филиал
                </button>
            }
        </div>

        <table class="main-table">
            <thead>
                <tr>
                    <th>Адрес</th>
                    <th>Организация</th>
                    <th></th>
                </tr>
            </thead>

            <tbody id="branchesBody"></tbody>
        </table>

        <div id="branchesPagination" class="pagination-container"></div>
    </div>
</div>

<div id="userModal" class="modal">
    <div class="modal-content large">
        <span class="close" id="closeModal">&times;</span>

        <div class="modal-header">
            <h3 id="modalTitle">Редактирование пользователя</h3>
        </div>

        <div class="modal-tabs">
            <button class="tab-button active" data-tab="tab-general" type="button">
                Основное
            </button>

            <button class="tab-button" data-tab="tab-permissions" type="button">
                Права
            </button>
        </div>

        <div class="tab-content active" id="tab-general">
            <div class="user-summary">
                <div class="photo-section">
                    <img id="photoPreview"
                         src="~/icons/default-avatar.png"
                         alt="Фото пользователя"
                         class="photo-preview" />

                    <label class="photo-upload-label">
                        <input type="file"
                               id="userPhoto"
                               accept="image/*"
                               hidden />

                        <button type="button"
                                class="btn small secondary"
                                id="uploadPhotoBtn">
                            Загрузить фото
                        </button>
                    </label>
                </div>

                <div class="fields-section">
                    <div class="fields-column">
                        <label>
                            ФИО
                            <input type="text"
                                   id="fullName"
                                   placeholder="Введите ФИО" />
                        </label>

                        <label>
                            Email
                            <input type="email"
                                   id="email"
                                   placeholder="Введите email" />
                        </label>
                    </div>

                    <div class="fields-column">
                        <label>
                            Логин
                            <input type="text"
                                   id="login"
                                   placeholder="Введите логин" />
                        </label>

                        <label>
                            Пароль
                            <div class="password-wrapper">
                                <input type="password"
                                       id="password"
                                       placeholder="Оставьте пустым" />

                                <button type="button"
                                        class="btn small secondary"
                                        id="generatePassword">
                                    Сгенерировать
                                </button>
                            </div>

                            <span class="password-hint">
                                Оставьте пустым, если не нужно менять пароль
                            </span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="options-group">
                <label class="option-label">
                    <input type="checkbox" id="sendEmail" />
                    <span>Отправить данные на email</span>
                </label>

                @if (Model.IsSuperAdmin)
                {
                    <label class="option-label">
                        <input type="checkbox" id="isSuperAdmin" />
                        <span>Супер-администратор</span>
                    </label>
                }
            </div>

            <div class="user-organizations">
                <h4>Организации и филиалы</h4>

                <div id="organizationsList"></div>
            </div>

            <div class="modal-actions">
                <button class="btn primary" id="nextToPermissions" type="button">
                    Далее
                </button>
            </div>
        </div>

        <div class="tab-content" id="tab-permissions">
            <div class="permissions-header">
                <div class="pattern-buttons">
                    <button class="btn small secondary pattern-btn" type="button">Администратор</button>
                    <button class="btn small secondary pattern-btn" type="button">Директор</button>
                    <button class="btn small secondary pattern-btn" type="button">Врач</button>
                    <button class="btn small secondary pattern-btn" type="button">Менеджер</button>
                    <button class="btn small secondary pattern-btn" type="button">Программист</button>
                    <button class="btn small secondary pattern-btn" type="button">Техподдержка</button>
                    <button class="btn small secondary pattern-btn" type="button">Бухгалтер</button>
                </div>

                <div class="apply-all">
                    <button class="btn small secondary"
                            id="openGlobalSelector"
                            type="button">
                        Выбрать организации и филиалы
                    </button>

                    <button class="btn small primary"
                            id="applyToAll"
                            type="button">
                        Применить ко всем
                    </button>
                </div>
            </div>

            <div id="permissionsContainer" class="permissions-container"></div>

            <div class="modal-actions">
                <button class="btn secondary" id="backToGeneral" type="button">
                    Назад
                </button>

                <button class="btn primary" id="saveUserBtn" type="button">
                    Сохранить
                </button>

                <button class="btn danger" id="cancelUserBtn" type="button">
                    Отмена
                </button>
            </div>
        </div>
    </div>
</div>

<div id="orgModal" class="modal">
    <div class="modal-content medium">
        <span class="close" id="closeOrgModal">&times;</span>

        <h3 id="orgModalTitle">Добавить организацию</h3>

        <div class="form-group">
            <label>
                Название
                <input type="text" id="orgName" />
            </label>

            <label>
                ИНН
                <input type="text" id="orgInn" />
            </label>

            <label>
                КПП
                <input type="text" id="orgKpp" />
            </label>

            <label>
                ОГРН
                <input type="text" id="orgOgrn" />
            </label>

            <label>
                Лимит часов по договору
                <input type="number"
                       id="orgWorkHoursLimit"
                       step="0.5"
                       min="0"
                       value="0" />
            </label>

            <label>
                Доступные продукты

                <div id="orgProductsContainer"
                     class="org-products-container">
                    <div class="loading-products">
                        Загрузка продуктов...
                    </div>
                </div>
            </label>
        </div>

        <div class="modal-actions">
            <button class="btn primary" id="saveOrgBtn" type="button">
                Сохранить
            </button>

            <button class="btn secondary" id="cancelOrgBtn" type="button">
                Отмена
            </button>
        </div>
    </div>
</div>

<div id="branchModal" class="modal">
    <div class="modal-content medium branch-modal-content">
        <span class="close" id="closeBranchModal">&times;</span>

        <h3 id="branchModalTitle">Добавить филиал</h3>

        <div class="branch-form-group">
            <label>
                Адрес филиала
                <input type="text"
                       id="branchAddress"
                       placeholder="Введите адрес филиала" />
            </label>

            <label>
                Организация
                <div id="branchOrgSelect"></div>
            </label>
        </div>

        <div class="modal-actions">
            <button class="btn primary" id="saveBranchBtn" type="button">
                Сохранить
            </button>

            <button class="btn secondary" id="cancelBranchBtn" type="button">
                Отмена
            </button>
        </div>
    </div>
</div>

<div id="orgBranchPopup" class="popup hidden">
    <div class="popup-content">
        <div class="popup-header">
            <h5>Выбор организаций и филиалов</h5>

            <span class="popup-close" id="closePopup">
                &times;
            </span>
        </div>

        <div id="popupOrgBranchTree"></div>

        <div class="popup-actions">
            <button class="btn primary" id="popupSave" type="button">
                Сохранить
            </button>
        </div>
    </div>
</div>

<form id="antiForgeryForm" method="post">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}